{
    "tasks": [
        {
            "type": "shell",
            "label": "C/C++: gcc build active file",
            "command": "/usr/bin/gcc",
            "args": [
                "-Wall",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-lm"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger.",
            "dependsOn": ["Ejecutar programa"]
        },
        { 
        "label": "Ejecutar programa",
        "type": "shell",
        "command": "bash",
        "args": [ "-c", 
        "exec ${fileDirname}/${fileBasenameNoExtension}" ], 
        "options": { 
            "cwd": "${fileDirname}" 
        } }
    ],
    "version": "2.0.0"
}